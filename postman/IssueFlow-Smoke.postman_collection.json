{
  "info": {
    "_postman_id": "issueflow-smoke-collection",
    "name": "IssueFlow API — Smoke (Critical Path)",
    "description": "Minimal end-to-end smoke suite (~22 requests, target <15 minutes). Validates auth, users, projects, tickets, dependencies, comments, mentions, workload, CSV export, soft-delete/restore, and audit log.\n\n**Prerequisites**: API running on {{baseUrl}}, migrations applied, seeded admin.\n\n**Run**: Select IssueFlow Local environment, set unique `testRunSuffix`, then **Run collection** (single folder, sequential). Reuses the same environment file as the full QA collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Smoke — Critical Path E2E",
      "description": "Run this folder sequentially with Collection Runner. No manual file uploads required.",
      "item": [
        {
          "name": "01 Login admin",
